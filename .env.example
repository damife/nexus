# SwiftNexus Enterprise - Environment Configuration
# Copy this file to .env and update with your actual values

# ===========================================
# DATABASE CONFIGURATION
# ===========================================
# PostgreSQL Database Connection
DB_HOST=localhost
DB_PORT=5432
DB_NAME=swiftnexus
DB_USER=swiftnexus_user
DB_PASSWORD=your_secure_password_here

# Database SSL Configuration (set to false for local development)
DB_SSL=false

# ===========================================
# SERVER CONFIGURATION
# ===========================================
# Server Port
PORT=3000

# Node Environment
NODE_ENV=development

# JWT Configuration
JWT_SECRET=your_jwt_secret_key_minimum_32_characters_long
JWT_EXPIRES_IN=7d

# ===========================================
# SWIFT CONFIGURATION
# ===========================================
# SWIFT Network Configuration
SWIFT_BIC=YOURBICXXX
SWIFT_ADDRESS=Your Bank Address
SWIFT_COUNTRY=US

# SWIFT GPI Configuration
SWIFT_GPI_ENABLED=true
SWIFT_GPI_API_KEY=your_gpi_api_key
SWIFT_GPI_ENDPOINT=https://swiftgpi.swift.com/api/v1

# ===========================================
# EMAIL CONFIGURATION
# ===========================================
# Resend Email Service
RESEND_API_KEY=re_your_resend_api_key_here
RESEND_FROM_EMAIL=noreply@swiftnexus.com

# SMTP Configuration (Alternative to Resend)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password

# ===========================================
# CRYPTO DEPOSIT CONFIGURATION
# ===========================================
# Bitcoin Configuration
BITCOIN_RPC_URL=http://localhost:8332
BITCOIN_RPC_USER=bitcoin_rpc_user
BITCOIN_RPC_PASSWORD=bitcoin_rpc_password

# Ethereum Configuration
ETHEREUM_RPC_URL=https://mainnet.infura.io/v3/your_infura_project_id
ETHEREUM_PRIVATE_KEY=your_ethereum_private_key
ETHEREUM_WALLET_ADDRESS=your_ethereum_wallet_address

# USDT (ERC-20) Configuration
USDT_CONTRACT_ADDRESS=0xdAC17F958D2ee523a2206206994597C13D831ec7

# ===========================================
# SECURITY CONFIGURATION
# ===========================================
# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# CORS Configuration
CORS_ORIGIN=http://localhost:3001

# Session Configuration
SESSION_SECRET=your_session_secret_key_minimum_32_characters

# ===========================================
# LOGGING CONFIGURATION
# ===========================================
# Log Level (error, warn, info, debug)
LOG_LEVEL=info

# Log File Path
LOG_FILE_PATH=./logs/app.log

# ===========================================
# FILE UPLOAD CONFIGURATION
# ===========================================
# File Upload Limits
MAX_FILE_SIZE=10485760
UPLOAD_PATH=./uploads

# ===========================================
# MONITORING CONFIGURATION
# ===========================================
# Health Check
HEALTH_CHECK_ENABLED=true

# Performance Monitoring
PERFORMANCE_MONITORING_ENABLED=true

# ===========================================
# DEVELOPMENT CONFIGURATION
# ===========================================
# Development Mode
DEV_MODE=true

# Auto-reload for development
AUTO_RELOAD=true

# Debug Mode
DEBUG=false
