{
  "name": "swiftnexus-enterprise",
  "version": "1.0.0",
  "description": "Enterprise SWIFT Message Platform",
  "type": "module",
  "private": true,
  "dependencies": {
    "axios": "^1.6.2",
    "bootstrap-icons": "^1.11.2",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.20.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.1.17",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.22",
    "glob": "^13.0.0",
    "postcss": "^8.5.6",
    "tailwindcss": "^4.1.17",
    "vite": "^5.0.8"
  },
  "scripts": {
    "dev": "vite --config config/vite.config.js",
    "build": "vite build --config config/vite.config.js",
    "preview": "vite preview --config config/vite.config.js",
    "build:css": "node config/build-css.js",
    "watch:css": "node node_modules/tailwindcss/lib/cli.js -i ./assets/css/tailwind.css -o ./assets/css/root.css --watch --config config/tailwind.config.js"
  }
}
