# ============================================================================
# SwiftNexus Enterprise - Environment Configuration
# ============================================================================
#
# INSTRUCTIONS:
# 1. Copy this file to .env in the same directory
# 2. Fill in all REQUIRED values (marked with comments)
# 3. Optional values can be left commented out if not needed
# 4. Never commit the actual .env file to version control
# 5. Generate secure secrets using: openssl rand -hex 64
#
# ============================================================================

# ============================================================================
# DATABASE CONFIGURATION (REQUIRED)
# ============================================================================
# PostgreSQL database connection settings
# These values are configured during installation via the UI installer

DB_HOST=localhost
DB_PORT=5432
DB_NAME=swiftnexus
DB_USER=postgres
DB_PASSWORD=your_secure_password_here

# Database SSL (set to 'true' for production with SSL)
DB_SSL=false

# Connection Pool Settings
DB_POOL_MAX=20


# ============================================================================
# JWT AUTHENTICATION (REQUIRED)
# ============================================================================
# Secret key for signing JWT tokens
# MUST be at least 32 characters long
# Generate with: openssl rand -hex 64

JWT_SECRET=your_very_long_random_secret_key_here_minimum_32_characters
JWT_EXPIRES_IN=24h


# ============================================================================
# APPLICATION CONFIGURATION (REQUIRED in Production)
# ============================================================================
# Server port
PORT=5000

# Node environment (development, production, test)
NODE_ENV=development

# Application URL (used for email links, callbacks, etc.)
APP_URL=http://localhost:3000

# CORS allowed origin (frontend URL)
CORS_ORIGIN=http://localhost:3000


# ============================================================================
# CRYPTOCURRENCY PAYMENT GATEWAY (NowPayments)
# ============================================================================
# Required for crypto deposit functionality
# Get your API keys from: https://nowpayments.io/

NOWPAYMENTS_API_KEY=your_nowpayments_api_key_here
NOWPAYMENTS_IPN_SECRET=your_nowpayments_ipn_secret_here


# ============================================================================
# EMAIL SERVICE CONFIGURATION (Optional)
# ============================================================================
# SMTP settings for sending emails (verification, notifications, etc.)
# Common providers:
# - Gmail: smtp.gmail.com:587 (use App Password, not regular password)
# - SendGrid: smtp.sendgrid.net:587
# - Mailgun: smtp.mailgun.org:587
# - AWS SES: email-smtp.us-east-1.amazonaws.com:587

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_specific_password

# Email sender details
EMAIL_FROM=noreply@swiftnexus.com
EMAIL_FROM_NAME=SwiftNexus Enterprise


# ============================================================================
# BACKUP CONFIGURATION
# ============================================================================
# Automatic database backup settings

BACKUP_ENABLED=true
BACKUP_SCHEDULE=0 2 * * *  # Daily at 2 AM (cron format)
BACKUP_RETENTION_DAYS=30
BACKUP_STORAGE_PATH=./backups
BACKUP_COMPRESSION=true

# Cloud backup (optional)
BACKUP_CLOUD_PROVIDER=none  # aws, gcp, azure, none
BACKUP_CLOUD_BUCKET=your-backup-bucket
BACKUP_CLOUD_REGION=us-east-1
BACKUP_CLOUD_ACCESS_KEY=your_cloud_access_key
BACKUP_CLOUD_SECRET_KEY=your_cloud_secret_key


# ============================================================================
# EMAIL VERIFICATION CONFIGURATION
# ============================================================================
# Email verification settings

EMAIL_VERIFICATION_REQUIRED=true
EMAIL_VERIFICATION_TOKEN_EXPIRES=24h
EMAIL_VERIFICATION_RESEND_LIMIT=5
EMAIL_VERIFICATION_TEMPLATE=verification

# Email templates
EMAIL_TEMPLATES_PATH=./templates/email
EMAIL_VERIFICATION_SUBJECT=Verify your SwiftNexus account
EMAIL_VERIFICATION_URL=${APP_URL}/verify-email?token={token}

# Password reset
PASSWORD_RESET_ENABLED=true
PASSWORD_RESET_TOKEN_EXPIRES=1h
PASSWORD_RESET_SUBJECT=Reset your SwiftNexus password
PASSWORD_RESET_URL=${APP_URL}/reset-password?token={token}


# ============================================================================
# TWO-FACTOR AUTHENTICATION (2FA)
# ============================================================================
# Application name for 2FA (shows in authenticator apps)
TWO_FACTOR_APP_NAME=SwiftNexus Enterprise

# 2FA token validity period (in seconds)
TWO_FACTOR_TOKEN_VALIDITY=300

# 2FA settings
TWO_FACTOR_REQUIRED=false
TWO_FACTOR_BACKUP_CODES_COUNT=10
TWO_FACTOR_ISSUER=SwiftNexus Enterprise


# ============================================================================
# MESSAGE QUEUE (RabbitMQ) - Optional
# ============================================================================
# Used for asynchronous message processing
# Format: amqp://user:password@host:port
# Default RabbitMQ: amqp://localhost:5672

RABBITMQ_URL=amqp://guest:guest@localhost:5672
RABBITMQ_QUEUE_NAME=swiftnexus_messages
RABBITMQ_EXCHANGE_NAME=swiftnexus_exchange
RABBITMQ_RETRY_ATTEMPTS=3
RABBITMQ_RETRY_DELAY=5000


# ============================================================================
# EVENT STREAMING (Kafka) - Optional
# ============================================================================
# Used for real-time event streaming and processing
# Format: host1:port1,host2:port2

KAFKA_BROKERS=localhost:9092
KAFKA_CLIENT_ID=swiftnexus-server
KAFKA_GROUP_ID=swiftnexus-group
KAFKA_TOPIC_PREFIX=swiftnexus


# ============================================================================
# LOGGING CONFIGURATION
# ============================================================================
# Log level: error, warn, info, debug
LOG_LEVEL=info

# Log file paths (relative to server directory)
LOG_DIR=logs
LOG_FILE_COMBINED=combined.log
LOG_FILE_ERROR=error.log
LOG_FILE_ACCESS=access.log

# Log rotation
LOG_MAX_SIZE=10m
LOG_MAX_FILES=5
LOG_DATE_PATTERN=YYYY-MM-DD


# ============================================================================
# SESSION CONFIGURATION
# ============================================================================
# Session secret for cookie signing
SESSION_SECRET=your_session_secret_here

# Session timeout in milliseconds (default: 24 hours)
SESSION_TIMEOUT=86400000

# Session store
SESSION_STORE=memory  # memory, redis, mongodb
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=your_redis_password


# ============================================================================
# RATE LIMITING
# ============================================================================
# API rate limit settings
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Payment-specific rate limit
PAYMENT_RATE_LIMIT_WINDOW_MS=900000
PAYMENT_RATE_LIMIT_MAX_REQUESTS=50

# Authentication rate limit
AUTH_RATE_LIMIT_WINDOW_MS=900000
AUTH_RATE_LIMIT_MAX_REQUESTS=10


# ============================================================================
# FILE UPLOAD CONFIGURATION
# ============================================================================
# Maximum file upload size in bytes (default: 10MB)
MAX_FILE_SIZE=10485760

# Allowed file types
ALLOWED_FILE_TYPES=image/jpeg,image/png,image/gif,application/pdf,text/plain,application/msword,application/vnd.openxmlformats-officedocument.wordprocessingml.document

# Upload directory (relative to server directory)
UPLOAD_DIR=uploads

# File validation
SCAN_UPLOADED_FILES=true
QUARANTINE_INFECTED_FILES=true


# ============================================================================
# SECURITY HEADERS
# ============================================================================
# Content Security Policy
CSP_DEFAULT_SRC='self'
CSP_SCRIPT_SRC='self'
CSP_STYLE_SRC='self' 'unsafe-inline'
CSP_IMG_SRC='self' data: https:
CSP_FONT_SRC='self'
CSP_CONNECT_SRC='self'
CSP_MEDIA_SRC='self'
CSP_OBJECT_SRC='none'
CSP_CHILD_SRC='none'
CSP_FRAME_ANCESTORS='none'
CSP_FORM_ACTION='self'
CSP_BASE_URI='self'

# Additional security headers
HELMET_ENABLED=true
X_FRAME_OPTIONS=DENY
X_CONTENT_TYPE_OPTIONS=nosniff
X_XSS_PROTECTION=1; mode=block
STRICT_TRANSPORT_SECURITY=max-age=31536000; includeSubDomains


# ============================================================================
# MONITORING AND ANALYTICS
# ============================================================================
# Application monitoring

MONITORING_ENABLED=false
SENTRY_DSN=your_sentry_dsn_here
NEW_RELIC_LICENSE_KEY=your_new_relic_key_here

# Analytics
GOOGLE_ANALYTICS_ID=your_ga_id_here
MIXPANEL_TOKEN=your_mixpanel_token_here


# ============================================================================
# API INTEGRATION
# ============================================================================
# External API keys and configurations

SWIFT_API_KEY=your_swift_api_key_here
SWIFT_API_URL=https://api.swift.com
SWIFT_API_TIMEOUT=30000

# Correspondent bank APIs
CORRESPONDENT_API_ENABLED=false
CORRESPONDENT_API_TIMEOUT=15000


# ============================================================================
# DEVELOPMENT CONFIGURATION
# ============================================================================
# Development-specific settings

DEBUG_MODE=false
MOCK_PAYMENTS=false
MOCK_EMAILS=false
MOCK_SWIFT_API=false

# Hot reload
HOT_RELOAD=true
WATCH_FILES=true


# ============================================================================
# PRODUCTION CONFIGURATION
# ============================================================================
# Production-specific settings

CLUSTER_MODE=false
CLUSTER_WORKERS=0  # 0 = number of CPU cores

# Performance
COMPRESSION_ENABLED=true
COMPRESSION_LEVEL=6
GZIP_ENABLED=true

# Caching
CACHE_ENABLED=true
CACHE_TTL=3600
CACHE_MAX_SIZE=100


# ============================================================================
# MAINTENANCE CONFIGURATION
# ============================================================================
# Maintenance mode settings

MAINTENANCE_MODE=false
MAINTENANCE_MESSAGE=SwiftNexus is currently under maintenance. Please try again later.
MAINTENANCE_ALLOWED_IPS=127.0.0.1,::1


# ============================================================================
# FEATURE FLAGS
# ============================================================================
# Enable/disable features

FEATURE_DASHBOARD_ANALYTICS=true
FEATURE_ADVANCED_REPORTING=true
FEATURE_MULTI_TENANT=false
FEATURE_API_V2=false
FEATURE_WEBHOOKS=true
FEATURE_BULK_OPERATIONS=true
FEATURE_SCHEDULED_TRANSFERS=true
FEATURE_CURRENCY_CONVERSION=true


# ============================================================================
# COMPLIANCE AND REGULATORY
# ============================================================================
# Compliance settings

AML_MONITORING_ENABLED=true
SANCTIONS_SCREENING_ENABLED=true
TRANSACTION_MONITORING_ENABLED=true
COMPLIANCE_REPORTING_ENABLED=true

# Data retention
DATA_RETENTION_DAYS=2555  # 7 years
AUDIT_LOG_RETENTION_DAYS=3650  # 10 years


# ============================================================================
# NOTIFICATIONS
# ============================================================================
# Notification settings

NOTIFICATION_EMAIL_ENABLED=true
NOTIFICATION_SMS_ENABLED=false
NOTIFICATION_PUSH_ENABLED=false

# SMS provider (optional)
SMS_PROVIDER=twilio  # twilio, nexmo, plivo
SMS_API_KEY=your_sms_api_key
SMS_API_SECRET=your_sms_api_secret
SMS_FROM_NUMBER=+1234567890


# ============================================================================
# WEBHOOK CONFIGURATION
# ============================================================================
# Webhook settings

WEBHOOK_ENABLED=true
WEBHOOK_SECRET=your_webhook_secret_here
WEBHOOK_TIMEOUT=10000
WEBHOOK_RETRY_ATTEMPTS=3
WEBHOOK_RETRY_DELAY=1000


# ============================================================================
# LEGACY COMPATIBILITY
# ============================================================================
# Legacy settings for backward compatibility

LEGACY_API_ENABLED=false
LEGACY_ENDPOINTS=/api/v1/legacy
LEGACY_AUTH_METHOD=basic
